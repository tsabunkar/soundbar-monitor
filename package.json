{
  "name": "soundbar-monitor",
  "version": "2.0.0",
  "description": "Menu bar mic waveform visualizer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder",
    "release": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.soundbar.monitor",
    "productName": "SoundBar Monitor",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "icon": "favicon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "tsabunkar",
      "repo": "soundbar-monitor"
    },
    "files": [
      "main.js",
      "preload.js",
      "favicon.png",
      "renderer/**/*"
    ]
  },
  "keywords": [
    "audio",
    "mic",
    "waveform",
    "visualizer"
  ],
  "author": "Tejas Sabunkar",
  "license": "MIT",
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^23.6.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
